{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Streamlit app",
      "type": "shell",
      "command": "cd prototype && if command -v uv >/dev/null 2>&1; then uv run streamlit run app.py; else streamlit run app.py; fi",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
