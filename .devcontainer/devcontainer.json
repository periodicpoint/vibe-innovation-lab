{
  "name": "Vibe Innovation Lab Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.10",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "containerEnv": {
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_SERVER_ADDRESS": "0.0.0.0",
    "STREAMLIT_SERVER_PORT": "8501",
    "STREAMLIT_SERVER_ENABLE_CORS": "false",
    "STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION": "false",
    "STREAMLIT_BROWSER_GATHER_USAGE_STATS": "false"
  },
  "customizations": {
    "vscode": {
      "settings": {
        // Auto-save every edit after a 1-second idle window. Browser-embedded
        // VS Code sometimes loses the Ctrl+S shortcut to the host browser,
        // which silently blocks the save. Auto-save eliminates that failure
        // mode entirely and also removes one manual step from the workshop
        // push flow (the previous "save all tabs" step becomes unnecessary).
        // afterDelay plays well with Streamlit hot reload: edits trigger a
        // hot reload roughly a second later without any user action.
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  // postCreateCommand runs a three-stage bootstrap. Stage order matters.
  //
  //   1. Python environment: try uv first (official framework tech stack),
  //      fall back to pip automatically if uv install or sync fails. The
  //      fallback is a safety net for workshop Codespaces: astral.sh being
  //      briefly unreachable must not block a non-programmer workshop. Both
  //      paths produce an equivalent environment because requirements.txt is
  //      auto-exported from pyproject.toml and carries the same dependency
  //      closure as the uv.lock file.
  //   2. Streamlit config: copy the pre-baked headless config into the user
  //      profile so port 8501 binds correctly on first `streamlit run`.
  //   3. Claude Code: install via npm if possible, otherwise print the
  //      fallback instruction so users can still paste the framework into any
  //      browser-based LLM.
  //
  // The stages are chained with `;` between stage 1 and stage 2 so that a
  // pip-fallback exit status does not abort stage 2. Stages 2 and 3 use `&&`
  // because stage 3 is optional but stage 2 is a hard prerequisite.
  "postCreateCommand": "((curl -LsSf https://astral.sh/uv/install.sh | sh) && export PATH=\"$HOME/.local/bin:$PATH\" && cd prototype && uv sync) || (echo 'uv install or sync failed, falling back to pip' && pip install -r prototype/requirements.txt) ; mkdir -p ~/.streamlit && cp prototype/.streamlit/config.toml ~/.streamlit/config.toml && (npm install -g @anthropic-ai/claude-code || echo 'Claude Code not installed. Use the copy-paste workflow: paste framework/orchestrator.md into any LLM.')",
  // postStartCommand runs on every Codespace start. Four stages, chained with
  // && because each one must succeed before the next can make sense:
  //   1. Refresh the Streamlit config in the user profile so port 8501 stays
  //      pinned even if the user tampered with ~/.streamlit/config.toml.
  //   2. Append an idempotent banner to ~/.bashrc that prints the forwarded
  //      app URL on every new interactive shell. The URL is built at shell
  //      start time from the Codespace-provided environment variables
  //      $CODESPACE_NAME and $GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN, so it
  //      is always accurate for the current Codespace without hardcoding.
  //      The VBI_APP_URL_BANNER marker makes the append idempotent across
  //      restarts and rebuilds.
  //   3. Launch Streamlit in the background inside a subshell, with output
  //      redirected to /tmp/streamlit.log for debugging. The `(... &)` outer
  //      subshell pattern orphans the child immediately so postStartCommand
  //      returns in milliseconds and VS Code considers the start phase done.
  //      The inner if/else picks uv run when uv is available and falls back
  //      to plain streamlit run when the pip bootstrap path was used during
  //      container creation. No port check is needed because postStartCommand
  //      runs exactly once per container start, when no previous Streamlit
  //      process from the same container can exist. This replaces the earlier
  //      .vscode/tasks.json approach, which required a one-time consent
  //      popup from the user and had a pgrep self-match bug in the
  //      idempotency check.
  //   4. Record a startup marker in /tmp/streamlit.log so the user can
  //      distinguish a fresh start from a stale log file.
  "postStartCommand": "mkdir -p ~/.streamlit && cp prototype/.streamlit/config.toml ~/.streamlit/config.toml && (grep -q 'VBI_APP_URL_BANNER' ~/.bashrc || (echo '# VBI_APP_URL_BANNER' >> ~/.bashrc && echo 'echo \"App-URL (öffnet sich nach streamlit run automatisch im Browser): https://${CODESPACE_NAME}-8501.${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}\"' >> ~/.bashrc)) && (echo \"--- Streamlit auto-start at $(date -u +%Y-%m-%dT%H:%M:%SZ) ---\" > /tmp/streamlit.log; cd prototype && (if command -v uv >/dev/null 2>&1; then uv run streamlit run app.py; else streamlit run app.py; fi) >> /tmp/streamlit.log 2>&1 &)",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  }
}
